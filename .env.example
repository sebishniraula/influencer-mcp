# AI Influencer Manager — Environment Variables
# Copy this file to .env and fill in your values

# LLM API key
OPENAI_API_KEY=sk-your-key-here

# Optional: override model at runtime (default is gpt-4o)
# JAC_LLM_MODEL=gpt-4o-mini

# Optional: Jac server settings (defaults shown)
# JAC_PORT=8000
# JAC_API_PORT=8001
